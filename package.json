{
    "name": "aurasci",
    "version": "0.3.0-base",
    "private": true,
    "description": "AuraSci frontend — Next.js + wagmi + SIWE wallet login. Talks to the backend at NEXT_PUBLIC_API_BASE_URL.",
    "scripts": {
        "dev": "concurrently --kill-others-on-fail -n next,warmup -c blue,magenta \"next dev --turbo -p 5173\" \"node scripts/warmup.mjs\"",
        "dev:nowarmup": "next dev --turbo -p 5173",
        "warmup": "node scripts/warmup.mjs",
        "build": "next build",
        "start": "next start",
        "preview": "next build && next start",
        "lint": "next lint"
    },
    "dependencies": {
        "@tanstack/react-query": "^5.100.14",
        "lucide-react": "^0.469.0",
        "next": "^14.2.21",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "three": "^0.160.0",
        "viem": "^2.51.2",
        "wagmi": "^2.19.5",
        "zustand": "^5.0.2"
    },
    "devDependencies": {
        "@types/node": "^22.10.5",
        "@types/react": "^18.3.18",
        "@types/react-dom": "^18.3.5",
        "@types/three": "^0.160.0",
        "@types/ws": "^8.18.1",
        "autoprefixer": "^10.4.27",
        "concurrently": "^9.2.1",
        "eslint": "^9.17.0",
        "eslint-config-next": "^15.1.6",
        "pino-pretty": "^13.1.3",
        "postcss": "^8.5.8",
        "tailwindcss": "^3.4.19",
        "typescript": "^5.7.2",
        "ws": "^8.21.0"
    }
}
