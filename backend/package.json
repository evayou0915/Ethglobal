{
  "name": "aurasci-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "AuraSci backend — Hono HTTP API + chain indexer worker. Deploys to a self-hosted server.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -n api,indexer,ai -c blue,green,magenta \"npm:dev:api\" \"npm:dev:indexer\" \"npm:dev:ai-worker\"",
    "dev:api": "tsx watch src/server.ts",
    "dev:indexer": "tsx watch src/indexer.ts",
    "dev:ai-worker": "tsx watch src/ai-worker.ts",
    "build": "tsc -p tsconfig.json",
    "start": "concurrently -n api,indexer,ai -c blue,green,magenta \"npm:start:api\" \"npm:start:indexer\" \"npm:start:ai-worker\"",
    "start:api": "node dist/server.js",
    "start:indexer": "node dist/indexer.js",
    "start:ai-worker": "node dist/ai-worker.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@prisma/client": "^5.22.0",
    "dotenv": "^16.4.7",
    "hono": "^4.6.14",
    "jose": "^5.9.6",
    "siwe": "^2.3.2",
    "unpdf": "^1.6.2",
    "viem": "^2.21.55",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "concurrently": "^9.2.1",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
