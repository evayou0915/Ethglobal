# ─── Contract deployment ──────────────────────────────────────────────
# Used by hardhat.config.ts when running `npm run deploy:sepolia`.
# Copy to `.env` and fill in.

# RPC endpoint for the deploy + verify. Public Base nodes work; for
# production scripts use Alchemy / QuickNode etc.
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_RPC_URL=https://mainnet.base.org

# Deployer wallet — must hold Base Sepolia ETH for gas. Get test ETH at
# https://www.alchemy.com/faucets/base-sepolia
# IMPORTANT: this is a DIFFERENT key from backend/.env SIGNER_PRIVATE_KEY.
# The deployer pays gas; the signer authorizes release/refund off-chain.
DEPLOYER_PRIVATE_KEY=0x

# USDC on the target chain (passed to the constructor).
#   Base mainnet:  0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
#   Base Sepolia:  0x036CbD53842c5426634e7929541eC2318f3dCF7e
USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# Backend signer PUBKEY (NOT the private key) — burned in as immutable.
# Derive from backend/.env SIGNER_PRIVATE_KEY:
#   node -e "console.log(require('viem/accounts').privateKeyToAccount('0xYOUR_KEY').address)"
SIGNER_ADDRESS=0x

# Optional: Basescan API key for automatic source verification post-deploy.
# Get a free one at https://basescan.org/myapikey
BASESCAN_API_KEY=
