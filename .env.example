# ─── Frontend env (Next.js, deployed to Vercel) ─────────────────────────
# Everything here is PUBLIC — `NEXT_PUBLIC_*` vars are bundled into the
# browser. Never put server-side secrets in this file.
#
# Server-side secrets (DATABASE_URL, SIGNER_PRIVATE_KEY, JWT_SECRET,
# PINATA_JWT, OPENAI_API_KEY, …) belong in `backend/.env` on your
# self-hosted server, NOT here.

# Where the backend lives. Used by the Next.js client to call /api/* on
# your self-hosted Hono server.
#   Local dev:   http://localhost:8787
#   Production:  https://api.yourdomain.com
NEXT_PUBLIC_API_BASE_URL=http://localhost:8787

# Chain config (must match what your backend / contract were deployed against).
#   8453  = Base mainnet
#   84532 = Base Sepolia (testnet)
NEXT_PUBLIC_CHAIN_ID=84532

# USDC token on the target chain.
#   Base mainnet:  0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
#   Base Sepolia:  0x036CbD53842c5426634e7929541eC2318f3dCF7e
NEXT_PUBLIC_USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# Deployed AuraSciEscrow address (from `cd contracts && npm run deploy:sepolia`).
NEXT_PUBLIC_ESCROW_ADDRESS=0x0000000000000000000000000000000000000000

# Optional: private RPC endpoints (recommended in prod — Alchemy/QuickNode/etc).
# If unset, falls back to the public Base nodes.
NEXT_PUBLIC_BASE_RPC_URL=https://mainnet.base.org
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# WalletConnect / Reown project id (free at https://cloud.reown.com).
NEXT_PUBLIC_WALLETCONNECT_ID=demo

